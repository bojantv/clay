{
  "id": "assigned-to-me",
  "name": "Auto-start issues assigned to me",
  "description": "Starts a session for each open bug assigned to you that is not yet In Progress or further along, excluding backend (BE:) issues. The agent works autonomously at ≥80% confidence and pauses for input otherwise.",
  "source": {
    "provider": "github",
    "kind": "issue",
    "repo": "trialview/v2",
    "ghAccount": "bojantv",
    "fetchLimit": 100
  },
  "filter": {
    "state": "open",
    "assigned": "me",
    "type": "bug",
    "skipProjectStatuses": ["🔄 In progress", "🔧 Dev Complete", "✍️ Ready for production", "✅ Done"],
    "titleExcludePrefixes": ["BE:"],
    "labels": {
      "exclude": ["BE", "backend"]
    }
  },
  "launch": {
    "defaultLimit": 10
  },
  "prompt": {
    "template": "assigned-to-me.md",
    "variables": {
      "confidence_threshold": "80"
    }
  },
  "session": {
    "title": "#{number} {title}",
    "vendor": "claude",
    "model": "default"
  },
  "completion": {
    "marker": "CLAY_TASK_COMPLETE",
    "needsInputMarker": "CLAY_NEEDS_INPUT",
    "closeSession": true,
    "archiveSession": true
  }
}
